# ClawWorld Gateway Configuration
# Copy to .env and fill in your keys

# Mode: "mock" (no keys needed) or "live" (real API calls)
CLAWWORLD_MODE=mock

# Anthropic API key — for Claude-based agents
ANTHROPIC_API_KEY=your-key

# xAI API key — for Grok-based agents
XAI_API_KEY=your-key

# Ollama runs locally (no key needed) — just make sure it's running: ollama serve

# Gateway port (default 18790)
CLAWWORLD_PORT=18790
